<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	<ThingDef ParentName="ChunkRockBase">
		<defName>BMT_ChunkCrystal</defName>
		<label>crystal chunk</label>
		<description>A chunk of crystal. Can be cut into usable crystal pieces.</description>
		<graphicData>
			<texPath>BMT_Caverns/Things/Chunks/CrystalChunk</texPath>
			<graphicClass>Graphic_Random</graphicClass>
		</graphicData>
		<statBases>
			<Mass>20</Mass>
		</statBases>
		<soundDrop>ChunkRock_Drop</soundDrop>
		<butcherProducts>
			<BMT_ResourceBlueCrystal>20</BMT_ResourceBlueCrystal>
		</butcherProducts>
	</ThingDef>

	<RecipeDef ParentName="MakeStoneBlocksBase">
		<defName>BMT_Make_BlueCrystals</defName>
		<label>make crystals</label>
		<description>Break crystal chunks into crystals.</description>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>BMT_ChunkCrystal</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>BMT_ChunkCrystal</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<BMT_ResourceBlueCrystal>20</BMT_ResourceBlueCrystal>
		</products>
	</RecipeDef>

</Defs>
