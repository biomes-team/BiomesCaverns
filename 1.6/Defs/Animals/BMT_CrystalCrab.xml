<Defs>
	<ThingDef ParentName="BiomesCore_CrabThingBase">
		<defName>BMT_CrystalCrab</defName>
		<label>crystal crab</label>
		<description>A large and powerful relative of the decorator crab, cavern crystals grow from the minerals on this crab's rocky shell. Despite its strong exoskeleton, the crystal crab hauls around this heavy shell, the reason for which is unknown. They are not known to breed in captivity.</description>
		<statBases>
			<MoveSpeed>3.5</MoveSpeed>
			<MarketValue>2300</MarketValue>
			<ComfyTemperatureMin>-55</ComfyTemperatureMin>
			<ComfyTemperatureMax>45</ComfyTemperatureMax>
			<FilthRate>16</FilthRate>
			<CaravanRidingSpeedFactor>1.2</CaravanRidingSpeedFactor>
			<Wildness>0.80</Wildness>
		</statBases>
		<uiIconScale>1.35</uiIconScale>
		<race>
			<canBePredatorPrey>false</canBePredatorPrey>
			<baseBodySize>2.4</baseBodySize>
			<predator>true</predator>
			<baseHealthScale>2</baseHealthScale>
			<foodType>CarnivoreAnimal</foodType>
			<leatherDef>BMT_RoyalChitin</leatherDef>
			<meatLabel>cave crab meat</meatLabel>
			<trainability>Intermediate</trainability>
			<packAnimal>false</packAnimal>
			<manhunterOnDamageChance>0.9</manhunterOnDamageChance>
			<manhunterOnTameFailChance>0.5</manhunterOnTameFailChance>
		</race>
		<tradeTags>
			<li>AnimalExotic</li>
		</tradeTags>

		<tools>
			<li>
				<label>claw</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>30</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadClaw</linkedBodyPartsGroup>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>25</power>
				<cooldownTime>4</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
			</li>
		</tools>
		<butcherProducts>
			<!-- crystal resource -->
			<BMT_ResourceBlueCrystal>75</BMT_ResourceBlueCrystal>
			<!-- <Sandstone>3</Sandstone> -->
		</butcherProducts>
	</ThingDef>

